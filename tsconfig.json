{
  "compilerOptions": {
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "allowJs": true,
    "esModuleInterop": true,
    "noEmit": true
  },
  "include": ["src"]
}